# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mieru_clinic?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="86400000"
RATE_LIMIT_MAX_REQUESTS="3"

# Email（メール送信に必要。未設定時はコンソールログのみ）
# SMTP_HOST: メールAPI のエンドポイントURL（例: https://api.resend.com/emails）
# SMTP_PASS: APIキー
# SMTP_FROM: 送信元メールアドレス（デフォルト: noreply@mieru-clinic.com）
# SMTP_HOST="https://api.resend.com/emails"
# SMTP_PASS="re_xxxxxxxx"
# SMTP_FROM="noreply@mieru-clinic.com"

# AI Advisory (optional - LLM分析を有効にする場合に設定)
# ANTHROPIC_API_KEY="sk-ant-..."
