# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mieru_clinic?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="86400000"
RATE_LIMIT_MAX_REQUESTS="3"

# Email — Resend（メール送信に必要。未設定時はコンソールログのみ）
# SMTP_HOST: Resend API エンドポイント
# SMTP_PASS: Resend API キー
# SMTP_FROM: 送信元（表示名 <アドレス> 形式推奨）
# SMTP_HOST="https://api.resend.com/emails"
# SMTP_PASS="re_xxxxxxxx"
# SMTP_FROM="MIERU Clinic <register@mieru-clinic.com>"

# AI Advisory (optional - LLM分析を有効にする場合に設定)
# ANTHROPIC_API_KEY="sk-ant-..."

# Stripe — 決済システム（有料プラン課金に必要。未設定時は決済機能が無効化）
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe Price IDs（Stripe Dashboardで作成したPrice IDを設定）
# STRIPE_PRICE_STARTER_MONTHLY="price_..."
# STRIPE_PRICE_STARTER_YEARLY="price_..."
# STRIPE_PRICE_STANDARD_MONTHLY="price_..."
# STRIPE_PRICE_STANDARD_YEARLY="price_..."
# STRIPE_PRICE_ENTERPRISE_MONTHLY="price_..."
# STRIPE_PRICE_ENTERPRISE_YEARLY="price_..."
