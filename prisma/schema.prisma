generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinic {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String
  slug                String   @unique
  googlePlaceId       String?  @map("google_place_id")
  unitCount           Int?     @map("unit_count")
  ownerUserId         String?  @unique @map("owner_user_id") @db.Uuid
  settings            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  owner                  User?    @relation("ClinicOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  staff                  Staff[]
  users                  User[]
  surveyTemplates        SurveyTemplate[]
  surveyResponses        SurveyResponse[]
  monthlyClinicMetrics   MonthlyClinicMetrics[]
  improvementActions     ImprovementAction[]
  authorizedDevices      AuthorizedDevice[]
  advisoryReports        AdvisoryReport[]
  kawaiiTeethCollections KawaiiTeethCollection[]

  @@map("clinics")
}

model Staff {
  id        String   @id @default(uuid()) @db.Uuid
  clinicId  String   @map("clinic_id") @db.Uuid
  name      String
  role      String   @default("staff")
  qrToken   String   @unique @default(uuid()) @map("qr_token")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clinic          Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  surveyResponses SurveyResponse[]
  user            User?

  @@index([clinicId])
  @@map("staff")
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  password          String
  name              String
  role              String
  clinicId          String?   @map("clinic_id") @db.Uuid
  staffId           String?   @unique @map("staff_id") @db.Uuid
  isActive          Boolean   @default(true) @map("is_active")
  emailVerified     DateTime? @map("email_verified")
  verificationToken String?   @unique @map("verification_token")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  clinic      Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  staff       Staff?  @relation(fields: [staffId], references: [id], onDelete: SetNull)
  ownedClinic Clinic? @relation("ClinicOwner")

  @@index([clinicId])
  @@map("users")
}

model SurveyTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  clinicId  String   @map("clinic_id") @db.Uuid
  name      String
  questions Json
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clinic          Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  surveyResponses SurveyResponse[]

  @@index([clinicId])
  @@map("survey_templates")
}

model SurveyResponse {
  id                 String   @id @default(uuid()) @db.Uuid
  clinicId           String   @map("clinic_id") @db.Uuid
  staffId            String?  @map("staff_id") @db.Uuid
  templateId         String   @map("template_id") @db.Uuid
  answers            Json
  overallScore       Float?   @map("overall_score")
  weightedScore      Float?   @map("weighted_score")
  trustFactor        Float?   @map("trust_factor")
  responseDurationMs Int?     @map("response_duration_ms")
  isVerified         Boolean  @default(true) @map("is_verified")
  deviceType         String?  @map("device_type")
  freeText           String?  @map("free_text")
  patientAttributes  Json?    @map("patient_attributes")
  ipHash             String?  @map("ip_hash")
  respondedAt        DateTime @default(now()) @map("responded_at")
  createdAt          DateTime @default(now()) @map("created_at")

  clinic   Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  staff    Staff?         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  template SurveyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([staffId])
  @@index([templateId])
  @@index([respondedAt])
  @@index([clinicId, respondedAt])
  @@index([clinicId, staffId])
  @@index([ipHash, respondedAt])
  @@index([clinicId, respondedAt, overallScore])
  @@index([clinicId, templateId, respondedAt])
  @@index([clinicId, isVerified, respondedAt])
  @@map("survey_responses")
}

model AuthorizedDevice {
  id           String   @id @default(uuid()) @db.Uuid
  clinicId     String   @map("clinic_id") @db.Uuid
  deviceUuid   String   @unique @map("device_uuid")
  name         String?
  isAuthorized Boolean  @default(true) @map("is_authorized")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@map("authorized_devices")
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model PlatformImprovementAction {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  detailedContent String?  @map("detailed_content")
  targetQuestionIds Json?  @map("target_question_ids") // ["fv2","tr5"]
  category        String?
  isPickup        Boolean  @default(false) @map("is_pickup")
  isActive        Boolean  @default(true) @map("is_active")
  serviceUrl      String?  @map("service_url")
  serviceProvider String?  @map("service_provider")
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  clinicActions ImprovementAction[]

  @@map("platform_improvement_actions")
}

model ImprovementAction {
  id            String    @id @default(uuid()) @db.Uuid
  clinicId      String    @map("clinic_id") @db.Uuid
  title         String
  description   String?
  targetQuestion   String?  @map("target_question")
  targetQuestionId String?  @map("target_question_id")
  baselineScore    Float?   @map("baseline_score")
  targetScore      Float?   @map("target_score")
  resultScore      Float?   @map("result_score")
  completionReason String?  @map("completion_reason") // established, uncertain, suspended
  completionNote   String?  @map("completion_note")
  status        String    @default("active") // active, completed, cancelled
  platformActionId String? @map("platform_action_id") @db.Uuid
  startedAt     DateTime  @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  platformAction PlatformImprovementAction? @relation(fields: [platformActionId], references: [id], onDelete: SetNull)
  logs   ImprovementActionLog[]

  @@index([clinicId])
  @@index([clinicId, status])
  @@map("improvement_actions")
}

model ImprovementActionLog {
  id                  String   @id @default(uuid()) @db.Uuid
  improvementActionId String   @map("improvement_action_id") @db.Uuid
  action              String   // started, completed, cancelled, reactivated
  satisfactionScore   Float?   @map("satisfaction_score")
  note                String?
  createdAt           DateTime @default(now()) @map("created_at")

  improvementAction ImprovementAction @relation(fields: [improvementActionId], references: [id], onDelete: Cascade)

  @@index([improvementActionId])
  @@map("improvement_action_logs")
}

model AdvisoryReport {
  id              String   @id @default(uuid()) @db.Uuid
  clinicId        String   @map("clinic_id") @db.Uuid
  triggerType     String   @map("trigger_type") // threshold, scheduled, manual
  responseCount   Int      @map("response_count")
  sections        Json     // AI分析結果のセクション
  summary         String   // 一言サマリー
  priority        String?  // 最優先改善領域
  generatedAt     DateTime @default(now()) @map("generated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([clinicId, generatedAt])
  @@map("advisory_reports")
}

model KawaiiTeeth {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String
  imageData   String   @map("image_data") @db.Text // base64 data URL
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  collections KawaiiTeethCollection[]

  @@map("kawaii_teeth")
}

model KawaiiTeethCollection {
  id            String   @id @default(uuid()) @db.Uuid
  clinicId      String   @map("clinic_id") @db.Uuid
  kawaiiTeethId String   @map("kawaii_teeth_id") @db.Uuid
  acquiredAt    DateTime @default(now()) @map("acquired_at")

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  kawaiiTeeth KawaiiTeeth @relation(fields: [kawaiiTeethId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([kawaiiTeethId])
  @@map("kawaii_teeth_collections")
}

model MonthlyClinicMetrics {
  id                         String   @id @default(uuid()) @db.Uuid
  clinicId                   String   @map("clinic_id") @db.Uuid
  year                       Int
  month                      Int
  firstVisitCount            Int?     @map("first_visit_count")
  firstVisitInsurance        Int?     @map("first_visit_insurance")
  firstVisitSelfPay          Int?     @map("first_visit_self_pay")
  revisitCount               Int?     @map("revisit_count")
  revisitInsurance           Int?     @map("revisit_insurance")
  revisitSelfPay             Int?     @map("revisit_self_pay")
  totalPatientCount          Int?     @map("total_patient_count")
  totalRevenue               Int?     @map("total_revenue")
  insuranceRevenue           Int?     @map("insurance_revenue")
  selfPayRevenue             Int?     @map("self_pay_revenue")
  cancellationCount          Int?     @map("cancellation_count")
  // 医院体制（半固定: 前月値を自動コピー）
  chairCount                 Int?     @map("chair_count")
  dentistCount               Float?   @map("dentist_count")
  hygienistCount             Float?   @map("hygienist_count")
  // 毎月入力
  totalVisitCount            Int?     @map("total_visit_count")
  workingDays                Int?     @map("working_days")
  // オプション
  laborCost                  Int?     @map("labor_cost")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, year, month])
  @@index([clinicId])
  @@map("monthly_clinic_metrics")
}

model AdminNotification {
  id        String   @id @default(uuid()) @db.Uuid
  type      String   // new_registration, etc.
  title     String
  message   String
  data      Json     @default("{}")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([isRead, createdAt])
  @@map("admin_notifications")
}
